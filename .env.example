# Career Computa operator configuration. Copy to .env (never commit .env).

# Telegram bot that delivers finished briefs to users (create via @BotFather).
TELEGRAM_PRODUCT_BOT_TOKEN=

# LLM lane for the pipeline (judgment steps). Default models: anthropic/claude-sonnet-4.6, haiku for classification.
OPENROUTER_API_KEY=

# Live web search inside research briefs (source URLs stored on every claim).
LINKUP_API_KEY=

# Speech-to-text for voice onboarding and optional task announcements.
# Also set as a Cloudflare Worker secret for the web API routes: npx wrangler secret put ELEVENLABS_API_KEY
ELEVENLABS_API_KEY=

# Optional: spoken announcements on delivered tasks (1 to enable).
ANNOUNCE=0
